{
	"name": "api-worker",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --port 8787 --inspector-port 9229",
		"dev:no-hot-cache": "wrangler dev --port 8787 --inspector-port 9229 --config .wrangler.local.no-hot-cache.toml",
		"dev:remote": "wrangler dev --remote --port 8787 --inspector-port 9229 --config .wrangler.remote.toml",
		"dev:remote:no-hot-cache": "wrangler dev --remote --port 8787 --inspector-port 9229 --config .wrangler.remote.no-hot-cache.toml",
		"deploy": "wrangler deploy",
		"db:migrate": "wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply DB --remote --config .wrangler.remote.toml",
		"build:wasm": "cargo build --manifest-path wasm/Cargo.toml --release --target wasm32-unknown-unknown && wasm-bindgen wasm/target/wasm32-unknown-unknown/release/worker_wasm_core.wasm --target web --out-dir src/wasm/generated"
	},
	"dependencies": {
		"@ai-workers/shared-core": "workspace:*",
		"hono": "^4.2.7"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20240222.0",
		"typescript": "^5.4.5",
		"wrangler": "^4.76.0"
	}
}
