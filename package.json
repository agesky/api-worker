{
	"name": "api-worker",
	"private": true,
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev:worker": "bun --cwd apps/worker dev",
		"dev:attempt-worker": "bun --cwd apps/attempt-worker dev",
		"prepare:remote-config": "node scripts/prepare-remote-config.mjs",
		"dev:worker:remote": "bun run prepare:remote-config -- --only worker && bun --cwd apps/worker dev:remote",
		"dev:attempt-worker:remote": "bun run prepare:remote-config -- --only attempt-worker && bun --cwd apps/attempt-worker dev:remote",
		"dev:ui": "bun --filter api-worker-ui dev -- --port 4173",
		"dev": "node scripts/dev.mjs",
		"dev:no-attempt-worker": "node scripts/dev.mjs --no-attempt-worker",
		"dev:worker-only": "node scripts/dev.mjs --worker-only",
		"dev:remote-db": "bun run prepare:remote-config && node scripts/dev.mjs --cloud-db",
		"deploy": "node scripts/deploy.mjs update --target both",
		"deploy:init": "node scripts/deploy.mjs init",
		"deploy:update": "node scripts/deploy.mjs update",
		"db:migrate:remote": "bun run prepare:remote-config -- --only worker && bun run --filter api-worker db:migrate:remote",
		"test": "vitest --passWithNoTests",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"format": "bunx --bun biome format --write .",
		"lint": "bunx --bun biome lint --write .",
		"check": "bunx --bun biome check --write .",
		"typecheck": "bunx --bun tsc --noEmit"
	},
	"devDependencies": {
		"@playwright/test": "^1.54.2",
		"@biomejs/biome": "2.3.15",
		"@types/node": "^20.11.30",
		"typescript": "^5.4.5",
		"vitest": "^1.5.3"
	},
	"dependencies": {
		"wrangler": "4"
	}
}
